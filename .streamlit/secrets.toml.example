# Copie ce fichier en .streamlit/secrets.toml (NON versionné) et remplis les valeurs.
#
# Côté MACHINE LOCALE (app.py) : les trois premières lignes suffisent pour PUBLIER.
# Côté APP PUBLIQUE (public.py, Streamlit Cloud) : ne mets QUE GIST_ID et GIST_USER
#   (surtout PAS le token : la page publique ne doit jamais pouvoir écrire).

GIST_ID = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"   # identifiant du Gist (dans son URL)
GIST_USER = "ton_login_github"                 # propriétaire du Gist
GIST_TOKEN = "github_pat_xxx"                  # token GitHub, scope "gist" (local seulement)

# Optionnel : nom du fichier dans le Gist (défaut : tournoi.json)
# GIST_FILE = "tournoi.json"

# Optionnel : URL de l'app publique, affichée dans la barre latérale pour la partager
# APP_PUBLIQUE_URL = "https://mon-tournoi.streamlit.app"
